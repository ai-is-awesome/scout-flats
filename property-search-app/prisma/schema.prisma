// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PropertySource {
  ZOLO
  STANZA
  COLIVE
  CUSTOM
  // custom = uploadedby someone
}

enum PropertyType {
  PG_CHAIN
  PG_INDEPENDENT
  HOSTEL
  COLIVING
  APARTMENT
}

enum Gender {
  MALE
  FEMALE
  UNISEX
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  PENDING_REVIEW
  REJECTED
}

enum UploadedVia {
  SCRIPT
  USER
}

enum SharingType {
  PRIVATE_ROOM
  DOUBLE_SHARING
  TRIPLE_SHARING
  TWO_BHK
  THREE_BHK
  STUDIO_APARTMENT
}

model Property {
  id                 String          @id @default(cuid())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  source             PropertySource
  uploadedVia        UploadedVia     @default(SCRIPT)
  propertyUniqueId   String?
  propertyInternalId String?
  providerJson       Json?
  name               String?
  description        String?
  genderAllowed      Gender?
  addressLine1       String?
  addressLine2       String?
  // Normalized location — see City and Locality models
  cityId             String?
  city               City?           @relation(fields: [cityId], references: [id])
  localityId         String?
  locality           Locality?       @relation(fields: [localityId], references: [id])
  // ZOLO STANDARD, SELECT
  propertyCategory   String?
  averageRating      Float?
  // Location
  latitude           Float?
  longitude          Float?
  status             PropertyStatus  @default(ACTIVE)
  // Images
  images             PropertyImage[]
  roomVariants       RoomVariant[]
  seoTitle           String?
  seoDescription     String?
  seoMeta            String?

  // For custom users
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([source, propertyUniqueId])
  @@unique([source, propertyInternalId])
  @@index([source])
  @@index([genderAllowed])
  @@index([cityId])
  @@index([localityId])
}

model User {
  id         String     @id @default(cuid())
  properties Property[]
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  imageUrl   String
  imageOrder Int
  imageLabel String?

  @@index([propertyId])
}

model City {
  id          String     @id @default(cuid())
  cityKey     String     @unique
  name        String
  stateName   String?
  countryCode String     @default("IN")
  localities  Locality[]
  properties  Property[]
}

model Locality {
  id          String     @id @default(cuid())
  cityId      String
  city        City       @relation(fields: [cityId], references: [id], onDelete: Cascade)
  localityKey String
  name        String
  properties  Property[]

  @@unique([cityId, localityKey])
  @@index([cityId])
}

model RoomVariant {
  id                 String       @id @default(cuid())
  updatedAt          DateTime     @updatedAt
  sharingType        SharingType?
  propertyId         String
  property           Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomName           String?
  isActive           Boolean      @default(true)
  depositMonths      Int?
  noticePeriodInDays Int?

  basePrice      Int
  variantLabel   String?
  variantDetails Json?
  pricingPlans   PricingPlan[]

  @@index([propertyId])
}

model PricingPlan {
  id                    String       @id @default(cuid())
  roomVariantId         String
  roomVariant           RoomVariant  @relation(fields: [roomVariantId], references: [id], onDelete: Cascade)
  durationMonths        Int
  discountPercentage    Float?
  depositMonths         Int?
  noticePeriodInDays    Int?
  effectiveMonthlyPrice Int?
  isBasePlan            Boolean
  promoOffers           PromoOffer[]
}

model PromoOffer {
  id                 String      @id @default(cuid())
  pricingPlanId      String
  pricingPlan        PricingPlan @relation(fields: [pricingPlanId], references: [id], onDelete: Cascade)
  promoCode          String?
  discountPercentage Float?
  applicableMonths   Int
  startDate          DateTime?
  endDate            DateTime?
}
